   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## \u00a76 \u2014 `consumes` (Lo consume) deep dive\n",
    "\n",
    "This is the central behavioral outcome of the study: did the baby *eat* the food on this test day?\n",
    "\n",
    "We look at:\n",
    "1. Overall acceptance rate\n",
    "2. Per-baby acceptance rates (who eats consistently? who refuses?)\n",
    "3. Trajectory over days (does repeated exposure increase consumption?)\n",
    "4. Co-occurrence with other behaviors (rejects, cries, touches, tries)\n",
    "5. Affective signature (valence/arousal of consumers vs non-consumers)\n",
    "6. Time-of-test relationship"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "# 6.1 \u2014 Overall acceptance\n",
    "print(\"=\"*60)\n",
    "print(\"LO CONSUME \u2014 overall distribution\")\n",
    "print(\"=\"*60)\n",
    "counts = cleaned[\"consumes\"].value_counts(dropna=False).sort_index()\n",
    "pct = (counts / len(cleaned) * 100).round(1)\n",
    "summary = pd.DataFrame({\"count\": counts, \"pct\": pct})\n",
    "labels = [\"No (0)\" if v == 0.0 else \"S\u00ed, poco (0.5)\" if v == 0.5\n",
    "          else \"S\u00ed (1)\" if v == 1.0 else \"NaN\" for v in counts.index]\n",
    "summary.index = labels\n",
    "print(summary.to_string())\n",
    "\n",
    "palette = {0.0: \"#d35454\", 0.5: \"#e8b939\", 1.0: \"#5a9b3a\"}\n",
    "colors = [palette.get(v, \"lightgray\") for v in counts.index]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7, 4))\n",
    "counts.plot(kind=\"bar\", ax=ax, color=colors)\n",
    "ax.set_xticklabels(labels, rotation=0)\n",
    "ax.set_ylabel(\"# patient-days\")\n",
    "ax.set_title(\"Lo consume \u2014 overall distribution\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "# 6.2 \u2014 Per-baby acceptance rate\n",
    "per_baby_consume = (\n",
    "    cleaned.groupby(\"patient_id\")[\"consumes\"]\n",
    "    .agg([\"mean\", \"count\"])\n",
    "    .rename(columns={\"mean\": \"acceptance_rate\", \"count\": \"n_days\"})\n",
    "    .sort_values(\"acceptance_rate\", ascending=False)\n",
    ")\n",
    "print(\"Per-baby acceptance rate (mean of `consumes`, ignoring NaN):\")\n",
    "print(per_baby_consume.round(3).to_string())\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(11, 4.5))\n",
    "per_baby_consume[\"acceptance_rate\"].plot(kind=\"bar\", ax=ax,\n",
    "    color=per_baby_consume[\"acceptance_rate\"].apply(\n",
    "        lambda v: \"#5a9b3a\" if v >= 0.75 else \"#e8b939\" if v >= 0.4 else \"#d35454\"\n",
    "    ),\n",
    ")\n",
    "ax.axhline(per_baby_consume[\"acceptance_rate\"].mean(), color=\"black\", linestyle=\"--\",\n",
    "           label=f\"cohort mean = {per_baby_consume['acceptance_rate'].mean():.2f}\")\n",
    "ax.set_ylabel(\"mean consumes (0\u20131)\")\n",
    "ax.set_ylim(0, 1.05)\n",
    "ax.set_title(\"Acceptance rate per baby\")\n",
    "ax.legend()\n",
    "plt.xticks(rotation=45, ha=\"right\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "# 6.3 \u2014 Trajectory over days: does consumption increase with repeated exposure?\n",
    "trajectory = (\n",
    "    cleaned.dropna(subset=[\"consumes\", \"day\"])\n",
    "    .groupby(\"day\")[\"consumes\"]\n",
    "    .agg([\"mean\", \"count\", \"std\"])\n",
    "    .reset_index()\n",
    ")\n",
    "trajectory = trajectory[trajectory[\"count\"] >= 3]   # only days with \u22653 babies\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(11, 5))\n",
    "ax.errorbar(trajectory[\"day\"], trajectory[\"mean\"],\n",
    "            yerr=trajectory[\"std\"] / np.sqrt(trajectory[\"count\"]),\n",
    "            marker=\"o\", color=\"#5a9b3a\", capsize=3)\n",
    "ax.set_xlabel(\"test day\")\n",
    "ax.set_ylabel(\"mean consumes\")\n",
    "ax.set_ylim(0, 1.05)\n",
    "ax.set_title(\"Consumption trajectory across test days (cohort mean \u00b1 SE)\\nshown only for days with \u22653 babies\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Also: per-baby trajectory (spaghetti plot)\n",
    "fig, ax = plt.subplots(figsize=(11, 6))\n",
    "for pid, grp in cleaned.groupby(\"patient_id\"):\n",
    "    grp_sorted = grp.dropna(subset=[\"consumes\", \"day\"]).sort_values(\"day\")\n",
    "    if len(grp_sorted) >= 3:\n",
    "        ax.plot(grp_sorted[\"day\"], grp_sorted[\"consumes\"], alpha=0.4, marker=\"o\", label=pid)\n",
    "ax.set_xlabel(\"test day\")\n",
    "ax.set_ylabel(\"consumes\")\n",
    "ax.set_title(\"Per-baby trajectory of `consumes` over days\")\n",
    "ax.set_ylim(-0.05, 1.05)\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "# 6.4 \u2014 Co-occurrence with other behaviors\n",
    "co_occur = cleaned.groupby(\"consumes\")[list(BEHAVIOR_COLS)].mean().T\n",
    "print(\"Mean of each behavior, grouped by consumes value:\")\n",
    "print(co_occur.round(3))\n",
    "\n",
    "label_for = {0.0: \"No (0)\", 0.5: \"S\u00ed, poco (0.5)\", 1.0: \"S\u00ed (1)\"}\n",
    "legend_labels = [label_for.get(v, str(v)) for v in co_occur.columns]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(9, 5))\n",
    "co_occur.plot(kind=\"bar\", ax=ax, colormap=\"RdYlGn\")\n",
    "ax.set_ylabel(\"mean behavior score\")\n",
    "ax.set_title(\"How other behaviors look when `consumes` = \" + \" / \".join(map(str, co_occur.columns)))\n",
    "ax.legend(title=\"consumes\", labels=legend_labels)\n",
    "plt.xticks(rotation=0)\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "# 6.5 \u2014 Affective signature: do consumers vs refusers have different valence/arousal?\n",
    "va_cols_present = [c for c in VA_COLS_BASE if c in cleaned.columns]\n",
    "va_by_consume = cleaned.groupby(\"consumes\")[va_cols_present].mean()\n",
    "print(\"Mean valence/arousal by consumes value:\")\n",
    "print(va_by_consume.round(3).T)\n",
    "\n",
    "label_for = {0.0: \"No (0)\", 0.5: \"S\u00ed, poco (0.5)\", 1.0: \"S\u00ed (1)\"}\n",
    "legend_labels = [label_for.get(v, str(v)) for v in va_by_consume.index]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(13, 5))\n",
    "va_by_consume.T.plot(kind=\"bar\", ax=ax, colormap=\"RdYlGn\")\n",
    "ax.set_ylabel(\"mean (0\u20131)\")\n",
    "ax.set_title(\"Affective signature by consumption outcome\")\n",
    "ax.legend(title=\"consumes\", labels=legend_labels)\n",
    "plt.xticks(rotation=45, ha=\"right\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "# 6.6 \u2014 Specifically: does valence-during-test track consumption?\n",
    "during_cols = [c for c in va_cols_present if \"_during\" in c]\n",
    "during_long = cleaned[[\"consumes\"] + during_cols].melt(id_vars=\"consumes\", var_name=\"signal\", value_name=\"value\")\n",
    "during_long = during_long.dropna()\n",
    "\n",
    "full_palette = {0.0: \"#d35454\", 0.5: \"#e8b939\", 1.0: \"#5a9b3a\"}\n",
    "present_vals = sorted(during_long[\"consumes\"].unique())\n",
    "palette = {v: full_palette[v] for v in present_vals if v in full_palette}\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(11, 5))\n",
    "sns.boxplot(data=during_long, x=\"signal\", y=\"value\", hue=\"consumes\",\n",
    "            ax=ax, palette=palette)\n",
    "ax.set_title(\"Valence/arousal DURING test, split by consumption\")\n",
    "plt.xticks(rotation=30, ha=\"right\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "# 6.7 \u2014 Test duration vs consumption\n",
    "duration_by_consume = cleaned.groupby(\"consumes\")[list(TIME_COLS)].mean()\n",
    "print(\"Mean test durations (seconds) by consumption outcome:\")\n",
    "print(duration_by_consume.round(2))\n",
    "\n",
    "label_for = {0.0: \"No (0)\", 0.5: \"S\u00ed, poco (0.5)\", 1.0: \"S\u00ed (1)\"}\n",
    "legend_labels = [label_for.get(v, str(v)) for v in duration_by_consume.index]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 4))\n",
    "duration_by_consume.T.plot(kind=\"bar\", ax=ax, colormap=\"RdYlGn\")\n",
    "ax.set_ylabel(\"seconds\")\n",
    "ax.set_title(\"Test duration by consumption outcome\")\n",
    "ax.legend(title=\"consumes\", labels=legend_labels)\n",
    "plt.xticks(rotation=0)\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## \u00a77 \u2014 Segregate into feature / meta / indicator matrices\n",
    "\n",
    "- `X_features` \u2014 numeric matrix for TDA\n",
    "- `X_meta` \u2014 `patient_id`, `day`, `day_flag`, `comments`\n",
    "- `X_indicators` \u2014 `*_fit_failed` and `*_was_missing` booleans"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "DROP_THRESHOLD = 0.60   # <- change here and re-run if you want stricter/looser\n",
    "\n",
    "meta_cols = [\"patient_id\", \"day\", \"day_flag\", \"comments\"]\n",
    "indicator_cols = [c for c in cleaned.columns if c.endswith((\"_fit_failed\", \"_was_missing\"))]\n",
    "candidate_features = [c for c in cleaned.columns\n",
    "                      if c not in meta_cols and c not in indicator_cols and c != \"day\"]\n",
    "\n",
    "col_missing = cleaned[candidate_features].isna().mean()\n",
    "kept = col_missing[col_missing <= DROP_THRESHOLD].index.tolist()\n",
    "dropped = col_missing[col_missing > DROP_THRESHOLD].index.tolist()\n",
    "\n",
    "X_meta = cleaned[[c for c in meta_cols if c in cleaned.columns]].copy()\n",
    "X_features = cleaned[kept].copy()\n",
    "X_indicators = cleaned[indicator_cols].copy()\n",
    "\n",
    "print(\"=\"*60)\n",
    "print(f\"SEGREGATE (threshold = {DROP_THRESHOLD})\")\n",
    "print(\"=\"*60)\n",
    "print(f\"X_features:    {X_features.shape}   (kept)\")\n",
    "print(f\"X_meta:        {X_meta.shape}\")\n",
    "print(f\"X_indicators:  {X_indicators.shape}\")\n",
    "print(f\"\\nDropped columns ({len(dropped)}):\")\n",
    "for c in dropped:\n",
    "    print(f\"   {c}  ({col_missing[c]:.1%} missing)\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## \u00a78 \u2014 Normalize (z-score + min-max, kept side-by-side)\n",
    "\n",
    "No imputation. NaNs are preserved. The indicator matrix carries the missingness signal."
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "def normalize(X, method=\"zscore\"):\n",
    "    out = X.copy().astype(float)\n",
    "    if method == \"zscore\":\n",
    "        mu = out.mean(skipna=True)\n",
    "        sigma = out.std(skipna=True).replace(0, np.nan)\n",
    "        out = (out - mu) / sigma\n",
    "    elif method == \"minmax\":\n",
    "        mn = out.min(skipna=True)\n",
    "        mx = out.max(skipna=True)\n",
    "        rng = (mx - mn).replace(0, np.nan)\n",
    "        out = (out - mn) / rng\n",
    "    return out\n",
    "\n",
    "\n",
    "X_z = normalize(X_features, \"zscore\")\n",
    "X_mm = normalize(X_features, \"minmax\")\n",
    "\n",
    "print(\"z-score summary (mean should be ~0, std ~1):\")\n",
    "print(X_z.describe().loc[[\"mean\", \"std\"]].T.round(3))\n"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "# Visual: distributions BEFORE vs AFTER z-score\n",
    "n_features = X_features.shape[1]\n",
    "ncols = 4\n",
    "nrows = (n_features + ncols - 1) // ncols\n",
    "\n",
    "fig, axes = plt.subplots(nrows, ncols, figsize=(15, 2.8 * nrows))\n",
    "for ax, col in zip(axes.flat, X_features.columns):\n",
    "    X_z[col].hist(ax=ax, bins=25, color=\"#4a90e2\", alpha=0.8)\n",
    "    ax.set_title(col, fontsize=9)\n",
    "    ax.tick_params(labelsize=7)\n",
    "for ax in axes.flat[n_features:]:\n",
    "    ax.axis(\"off\")\n",
    "plt.suptitle(\"Normalized feature distributions (z-score)\", y=1.002, fontsize=14)\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "# Visual: min-max distributions side-by-side for the same features\n",
    "fig, axes = plt.subplots(nrows, ncols, figsize=(15, 2.8 * nrows))\n",
    "for ax, col in zip(axes.flat, X_features.columns):\n",
    "    X_mm[col].hist(ax=ax, bins=25, color=\"#5a9b3a\", alpha=0.8)\n",
    "    ax.set_title(col, fontsize=9)\n",
    "    ax.tick_params(labelsize=7)\n",
    "for ax in axes.flat[n_features:]:\n",
    "    ax.axis(\"off\")\n",
    "plt.suptitle(\"Normalized feature distributions (min-max)\", y=1.002, fontsize=14)\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## \u00a79 \u2014 Pre-TDA exploration\n",
    "\n",
    "Spearman correlation matrix + PCA + UMAP. All colored by `consumes` so you can see\n",
    "whether the topology of the feature space already separates accepters from rejecters."
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "# 9.1 \u2014 Spearman correlation matrix\n",
    "plt.figure(figsize=(11, 9))\n",
    "corr = X_features.corr(method=\"spearman\")\n",
    "sns.heatmap(corr, cmap=\"RdBu_r\", center=0, vmin=-1, vmax=1, square=True,\n",
    "            cbar_kws={\"shrink\": 0.7})\n",
    "plt.title(\"Spearman correlation among features\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "# 9.2 \u2014 PCA (uses median fill ONLY for the projection, not for saved outputs)\n",
    "from sklearn.decomposition import PCA\n",
    "\n",
    "X_for_proj = X_z.fillna(X_z.median(numeric_only=True))\n",
    "pca = PCA(n_components=2)\n",
    "coords = pca.fit_transform(X_for_proj)\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(15, 6))\n",
    "\n",
    "# Left: colored by patient_id\n",
    "sc1 = axes[0].scatter(coords[:, 0], coords[:, 1],\n",
    "                      c=X_meta[\"patient_id\"].astype(\"category\").cat.codes,\n",
    "                      cmap=\"tab20\", alpha=0.7, s=40)\n",
    "axes[0].set_xlabel(f\"PC1 ({pca.explained_variance_ratio_[0]:.1%})\")\n",
    "axes[0].set_ylabel(f\"PC2 ({pca.explained_variance_ratio_[1]:.1%})\")\n",
    "axes[0].set_title(\"PCA \u2014 colored by patient_id\")\n",
    "\n",
    "# Right: colored by consumes\n",
    "sc2 = axes[1].scatter(coords[:, 0], coords[:, 1],\n",
    "                      c=cleaned[\"consumes\"], cmap=\"RdYlGn\", alpha=0.7, s=40,\n",
    "                      vmin=0, vmax=1)\n",
    "axes[1].set_xlabel(f\"PC1 ({pca.explained_variance_ratio_[0]:.1%})\")\n",
    "axes[1].set_ylabel(f\"PC2 ({pca.explained_variance_ratio_[1]:.1%})\")\n",
    "axes[1].set_title(\"PCA \u2014 colored by `consumes`\")\n",
    "plt.colorbar(sc2, ax=axes[1], label=\"consumes\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "# 9.3 \u2014 UMAP\n",
    "import umap\n",
    "reducer = umap.UMAP(n_neighbors=15, min_dist=0.1, random_state=42)\n",
    "embedding = reducer.fit_transform(X_for_proj)\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(15, 6))\n",
    "axes[0].scatter(embedding[:, 0], embedding[:, 1],\n",
    "                c=X_meta[\"patient_id\"].astype(\"category\").cat.codes,\n",
    "                cmap=\"tab20\", alpha=0.7, s=40)\n",
    "axes[0].set_title(\"UMAP \u2014 colored by patient_id\")\n",
    "\n",
    "sc = axes[1].scatter(embedding[:, 0], embedding[:, 1],\n",
    "                     c=cleaned[\"consumes\"], cmap=\"RdYlGn\", alpha=0.7, s=40,\n",
    "                     vmin=0, vmax=1)\n",
    "axes[1].set_title(\"UMAP \u2014 colored by `consumes`\")\n",
    "plt.colorbar(sc, ax=axes[1], label=\"consumes\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## \u00a710 \u2014 Save and download cleaned outputs"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "cleaned.to_csv(OUTPUT_DIR / \"cleaned_long.csv\", index=False)\n",
    "X_features.to_csv(OUTPUT_DIR / \"X_features.csv\", index=False)\n",
    "X_indicators.to_csv(OUTPUT_DIR / \"X_indicators.csv\", index=False)\n",
    "X_meta.to_csv(OUTPUT_DIR / \"X_meta.csv\", index=False)\n",
    "X_z.to_csv(OUTPUT_DIR / \"X_features_zscore.csv\", index=False)\n",
    "X_mm.to_csv(OUTPUT_DIR / \"X_features_minmax.csv\", index=False)\n",
    "\n",
    "saved = list(OUTPUT_DIR.glob(\"*.csv\"))\n",
    "print(f\"Saved {len(saved)} CSV files to {OUTPUT_DIR.resolve()}:\")\n",
    "for f in saved:\n",
    "    print(f\"   {f.name:<35} ({f.stat().st_size/1024:.1f} KB)\")\n"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "# Download all saved CSVs (Colab only)\n",
    "try:\n",
    "    from google.colab import files\n",
    "    for f in saved:\n",
    "        files.download(str(f))\n",
    "except ImportError:\n",
    "    print(f\"Files are in {OUTPUT_DIR.resolve()}\")\n"
   ]
